<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ancient">

    <!-- Ornate top gold band -->
    <View
        android:id="@+id/topBanner"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/band_gold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App title header -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_title_ta"
        android:textSize="20sp"
        android:textColor="@color/gold_light"
        android:fontFamily="serif"
        android:letterSpacing="0.06"
        android:shadowColor="@color/bg_edge"
        android:shadowDx="0"
        android:shadowDy="2"
        android:visibility="gone"
        android:shadowRadius="4"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/topBanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/appSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_title_en"
        android:textSize="11sp"
        android:textColor="@color/gold_dim"
        android:letterSpacing="0.28"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider ornament under the header -->
    <View
        android:id="@+id/headerRule"
        android:layout_width="200dp"
        android:layout_height="2dp"
        android:background="@drawable/title_ornament"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/appSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Swipeable doll pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerRule"
        app:layout_constraintBottom_toTopOf="@id/pageIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Page indicator diamonds -->
    <LinearLayout
        android:id="@+id/pageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/dot0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_light"
            android:layout_marginHorizontal="6dp" />

        <TextView
            android:id="@+id/dot1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_dim"
            android:layout_marginHorizontal="6dp" />

        <TextView
            android:id="@+id/dot2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_dim"
            android:layout_marginHorizontal="6dp" />

        <TextView
            android:id="@+id/dot3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_dim"
            android:layout_marginHorizontal="6dp" />

        <TextView
            android:id="@+id/dot4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_dim"
            android:layout_marginHorizontal="6dp" />

        <TextView
            android:id="@+id/dot5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/indicator_dot"
            android:textSize="11sp"
            android:textColor="@color/gold_dim"
            android:layout_marginHorizontal="6dp" />

    </LinearLayout>

    <!-- Ornate bottom gold band -->
    <View
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/band_gold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

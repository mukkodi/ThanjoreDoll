<?xml version="1.0" encoding="utf-8"?>
<!-- Temple-niche frame: a softly filled rounded panel with a double gold border,
     like the recessed alcove a deity or doll is displayed in. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer bright gold rim -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/niche_fill" />
            <stroke android:width="2dp" android:color="@color/gold_light" />
        </shape>
    </item>

    <!-- Inner thin gold line, inset to read as a beaded double frame -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/gold_dim" />
        </shape>
    </item>

</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<!-- Slim decorative rule that fades in from the edges toward a gold centre,
     placed under a title like a temple inscription divider. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#00C8972B"
        android:centerColor="@color/gold_light"
        android:endColor="#00C8972B" />
    <corners android:radius="1dp" />
</shape>

<?xml version="1.0" encoding="utf-8"?>
<!-- Aged temple-wall backdrop: a warm radial glow fading to dark edges. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="70%p"
        android:centerX="0.5"
        android:centerY="0.42"
        android:startColor="@color/bg_warm"
        android:centerColor="@color/bg_deep"
        android:endColor="@color/bg_edge" />
</shape>
